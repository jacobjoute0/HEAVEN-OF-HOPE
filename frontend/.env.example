VITE_API_URL=http://localhost:5000/api

# Firebase client SDK — copy values from Firebase Console → Project Settings → General
# Replace every placeholder below with the real values from your Firebase project.
VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=REPLACE_WITH_YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_YOUR_APP_ID

# Optional: connect the frontend SDK to local Firebase emulators during development.
VITE_USE_FIREBASE_EMULATOR=false
VITE_FIREBASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_AUTH_EMULATOR_PORT=9100
VITE_FIRESTORE_EMULATOR_PORT=8089
VITE_FIREBASE_STORAGE_EMULATOR_PORT=9200

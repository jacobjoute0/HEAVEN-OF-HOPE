{
"hosting": {
"public": "frontend/dist",
"ignore": [
"firebase.json",
"**/.*",
"**/node_modules/**"
],
"rewrites": [
{
"source": "/api/**",
"destination": "http://127.0.0.1:5001/api"
}
]
},
"firestore": {
"rules": "firestore.rules"
},
"storage": {
"rules": "storage.rules"
},
"database": {
"rules": "database.rules.json"
},
"emulators": {
"auth": {
"host": "127.0.0.1",
"port": 9100
},
"firestore": {
"host": "127.0.0.1",
"port": 8089
},
"database": {
"host": "127.0.0.1",
"port": 9011
},
"storage": {
"host": "127.0.0.1",
"port": 9200
},
"hosting": {
"host": "127.0.0.1",
"port": 5001
},
"ui": {
"enabled": true,
"host": "127.0.0.1",
"port": 4000
}
}
}

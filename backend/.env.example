PORT=5000
FRONTEND_URL=http://localhost:5173
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Optional: connect the backend Admin SDK to local Firebase emulators.
USE_FIREBASE_EMULATOR=false
FIREBASE_EMULATOR_HOST=127.0.0.1
FIREBASE_AUTH_EMULATOR_PORT=9100
FIRESTORE_EMULATOR_PORT=8089
FIREBASE_STORAGE_EMULATOR_PORT=9200

# SMTP (email service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Razorpay (payment service)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# QR attendance signing secret
QR_SECRET=haven-of-hope-qr-secret-key
